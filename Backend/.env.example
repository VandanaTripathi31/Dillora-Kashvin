# ============================================================
# Dillora Backend — environment variables
# Copy this file to `.env` and fill in real values.
# NEVER commit the real .env — it is gitignored.
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# Comma-separated list of allowed origins (frontend + dashboard dev URLs)
FRONTEND_URL=http://localhost:3000,http://localhost:3001

# MongoDB — if your password contains special characters like @ : / ?
# they MUST be URL-encoded (e.g. @ -> %40) or the connection will fail.
MONGO_URI=mongodb+srv://<user>:<url-encoded-password>@<cluster>/dillora

# JWT — use a long random string (e.g. `openssl rand -hex 32`)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Default admin — used by `npm run seed` to create the first admin login
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@dillora.com
ADMIN_PASSWORD=change-me

# Cloudinary (media storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (payments — optional, only if online payment is enabled)
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=
